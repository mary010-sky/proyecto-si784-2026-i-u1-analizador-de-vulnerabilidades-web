# ============================================================
# VulnScan Platform - Environment Variables
# ============================================================

# ── Database (MySQL nativo) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=vulnuser
DB_PASSWORD=TU_PASSWORD_MYSQL
DB_NAME=vulnscan
DATABASE_URL=mysql+pymysql://vulnuser:TU_PASSWORD_MYSQL@localhost:3306/vulnscan

# ── Seguridad JWT ────────────────────────────────────────────
# Generar con: openssl rand -hex 32
SECRET_KEY=cambia-esto-genera-con-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── DeepSeek AI ──────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-tu-api-key-aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ── Servidor ─────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
ENVIRONMENT=production

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://149.34.48.176,https://tu-dominio.com

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_SCAN=10/minute

# ── Logs ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=/var/log/vulnscan/backend.log
